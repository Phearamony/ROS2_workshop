self.sub = self.create_subscription(
Int32, '/counter', self.on_msg, 10)
def on_msg(self, msg):
self.get_logger().info(f'Received: {msg.data}')
def main(args=None):
rclpy.init(args=args)
rclpy.spin(CounterSubscriber())
rclpy.shutdown()
